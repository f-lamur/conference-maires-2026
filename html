<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Conseil en Énergies de Proximité — Hérault Énergies</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,700;1,400&display=swap');

:root {
  --turquoise: #38B6AB;
  --turquoise-dark: #2a8f87;
  --magenta: #B50067;
  --magenta-light: #d4007a;
  --lime: #BCCF21;
  --yellow: #F9B104;
  --bg: #ffffff;
  --bg-card: #f5f6f8;
  --bg-card-alt: #eef0f4;
  --border: #e0e3ea;
  --text: #1a1e2a;
  --text-muted: #5c6478;
  --slide-max: 920px;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html, body {
  font-family: 'Outfit', sans-serif;
  background: var(--bg);
  color: var(--text);
  height: 100%; width: 100%;
  overflow: hidden;
  -webkit-font-smoothing: antialiased;
}

.deck { height: 100%; width: 100%; position: relative; overflow: hidden; }

.slide {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; justify-content: flex-start; align-items: center;
  padding: 2rem 1.5rem 4rem;
  opacity: 0; pointer-events: none;
  overflow-y: auto; -webkit-overflow-scrolling: touch;
  transition: opacity 0.35s ease;
}
.slide.active { opacity: 1; pointer-events: auto; }

.slide-inner { max-width: var(--slide-max); width: 100%; }

/* Navigation */
.nav-bar {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: center; gap: 0.5rem;
  padding: 0.8rem 1rem;
  background: linear-gradient(transparent, rgba(255,255,255,0.95) 30%);
}
.nav-dot {
  width: 10px; height: 10px; border-radius: 50%;
  background: var(--border); border: none; cursor: pointer; transition: all 0.3s;
}
.nav-dot.active {
  background: var(--magenta); box-shadow: 0 0 8px rgba(181,0,103,0.3); transform: scale(1.3);
}

.nav-arrows { position: fixed; top: 50%; transform: translateY(-50%); z-index: 100; }
.nav-arrows.left { left: 0.5rem; }
.nav-arrows.right { right: 0.5rem; }
.arrow-btn {
  width: 36px; height: 36px; border-radius: 50%;
  border: 1px solid var(--border); background: rgba(255,255,255,0.8);
  color: var(--text-muted); font-size: 1rem; cursor: pointer; transition: all 0.2s;
  display: flex; align-items: center; justify-content: center; backdrop-filter: blur(8px);
}
.arrow-btn:hover { border-color: var(--magenta); color: var(--magenta); }

.slide-counter {
  position: fixed; top: 0.8rem; right: 1rem;
  font-size: 0.65rem; color: var(--text-muted); letter-spacing: 0.1em; z-index: 100;
}

/* Typography */
.serif { font-family: 'Playfair Display', serif; }
h1 { font-size: clamp(1.8rem, 5vw, 3rem); font-weight: 800; line-height: 1.15; color: var(--text); }
h2 { font-size: clamp(1.3rem, 3.5vw, 1.9rem); font-weight: 700; line-height: 1.2; margin-bottom: 0.8rem; color: var(--text); }
h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.4rem; color: var(--text); }
p, li { font-size: 0.88rem; line-height: 1.6; color: var(--text-muted); font-weight: 300; }

.accent { color: var(--turquoise); }
.accent-m { color: var(--magenta); }
.accent-l { color: var(--lime); }
.accent-y { color: var(--yellow); }

.tag {
  display: inline-block; padding: 0.2rem 0.7rem; border-radius: 20px;
  font-size: 0.62rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase;
}
.tag-turq { background: rgba(56,182,171,0.1); color: var(--turquoise); border: 1px solid rgba(56,182,171,0.25); }
.tag-mag { background: rgba(181,0,103,0.08); color: var(--magenta); border: 1px solid rgba(181,0,103,0.2); }
.tag-lime { background: rgba(188,207,33,0.1); color: #7a8a00; border: 1px solid rgba(188,207,33,0.3); }

/* Cards */
.card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 10px; padding: 1.1rem; margin-bottom: 0.7rem;
}
.card-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
@media (max-width: 500px) { .card-row { grid-template-columns: 1fr; } }

.stat-card { text-align: center; padding: 0.8rem; }
.stat-val { font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 800; line-height: 1; margin-bottom: 0.2rem; }
.stat-label { font-size: 0.68rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; }

/* Bars */
.bar-row { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.4rem; }
.bar-label { font-size: 0.72rem; min-width: 70px; text-align: right; color: var(--text-muted); }
.bar-track { flex: 1; height: 16px; background: rgba(0,0,0,0.04); border-radius: 4px; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 4px; transition: width 1s ease; width: 0; }
.bar-val { font-size: 0.7rem; font-weight: 600; min-width: 50px; }

/* Donut */
.donut-row { display: flex; align-items: center; gap: 1.2rem; flex-wrap: wrap; }
.donut-wrap { width: 110px; height: 110px; position: relative; flex-shrink: 0; }
.donut-wrap svg { width: 100%; height: 100%; transform: rotate(-90deg); }
.donut-center {
  position: absolute; inset: 0; display: flex; align-items: center;
  justify-content: center; flex-direction: column;
}
.donut-legend { flex: 1; min-width: 130px; }
.legend-item { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.35rem; font-size: 0.75rem; color: var(--text-muted); }
.legend-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }

/* Gauge */
.gauge-row { display: flex; gap: 0.8rem; flex-wrap: wrap; justify-content: center; }
.gauge-item { text-align: center; flex: 1; min-width: 90px; }
.gauge-bar { height: 5px; border-radius: 3px; background: rgba(0,0,0,0.06); overflow: hidden; margin: 0.3rem 0; }
.gauge-fill { height: 100%; border-radius: 3px; transition: width 1s ease; width: 0; }
.gauge-val { font-size: 1.1rem; font-weight: 800; }
.gauge-label { font-size: 0.62rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }

/* Timeline */
.timeline { position: relative; padding-left: 1.4rem; margin-top: 0.6rem; }
.timeline::before {
  content: ''; position: absolute; left: 4px; top: 0; bottom: 0; width: 2px;
  background: linear-gradient(var(--turquoise), var(--magenta), var(--lime)); border-radius: 2px;
}
.tl-item { position: relative; margin-bottom: 0.8rem; padding-left: 0.8rem; }
.tl-item::before {
  content: ''; position: absolute; left: -1.4rem; top: 5px;
  width: 10px; height: 10px; border-radius: 50%;
  border: 2px solid var(--turquoise); background: var(--bg);
}
.tl-year { font-size: 0.68rem; font-weight: 600; color: var(--turquoise); letter-spacing: 0.05em; }
.tl-text { font-size: 0.78rem; color: var(--text-muted); line-height: 1.45; }

/* Icon grid */
.icon-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr)); gap: 0.6rem; margin-top: 0.6rem; }
.icon-item {
  text-align: center; padding: 0.8rem 0.4rem; background: var(--bg-card);
  border: 1px solid var(--border); border-radius: 8px; transition: border-color 0.3s;
}
.icon-item:hover { border-color: var(--turquoise); }
.icon-item .emoji { font-size: 1.6rem; margin-bottom: 0.3rem; }
.icon-item .icon-label { font-size: 0.68rem; color: var(--text-muted); line-height: 1.3; }

/* Images */
.slide-img {
  display: block; max-width: 100%; height: auto; border-radius: 8px;
  margin: 0.6rem auto; border: 1px solid var(--border);
}
.slide-img.no-border { border: none; }

/* Contact */
.contact-card {
  background: linear-gradient(135deg, rgba(56,182,171,0.06), rgba(181,0,103,0.04));
  border: 1px solid rgba(56,182,171,0.15); border-radius: 12px; padding: 1.3rem; text-align: center;
}
.contact-detail {
  display: inline-flex; align-items: center; gap: 0.3rem;
  margin: 0.2rem 0.5rem; font-size: 0.82rem; color: var(--turquoise); font-weight: 500;
}

.divider {
  width: 50px; height: 3px;
  background: linear-gradient(90deg, var(--turquoise), var(--magenta));
  border-radius: 2px; margin: 0.8rem 0;
}

.logo-header {
  position: fixed; top: 0.6rem; left: 0.8rem; z-index: 100;
  height: 38px; opacity: 0.85;
}

@media (max-width: 600px) {
  .slide { padding: 1rem 0.8rem 3.5rem; }
  .nav-arrows { display: none; }
  .card { padding: 0.8rem; }
  .logo-header { height: 30px; top: 0.5rem; left: 0.5rem; }
}
</style>
</head>
